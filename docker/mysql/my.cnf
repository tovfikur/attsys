[mysqld]
# Use faster legacy auth plugin — eliminates RSA key exchange on first connect.
# caching_sha2_password (default in MySQL 8.0) requires ~5s RTT without SSL.
default_authentication_plugin = mysql_native_password

# Performance tuning
max_connections = 50
innodb_buffer_pool_size = 128M
innodb_flush_log_at_trx_commit = 2
innodb_log_buffer_size = 16M
query_cache_type = 0
